# Example Caddy reverse proxy configuration.
# Not used by default — the stack runs plain HTTP on direct ports.
#
# To use: add a caddy service to docker-compose.yml, or run Caddy
# on the host and point it at the exposed service ports.
#
# gitlab.dev.local {
#   tls internal
#   reverse_proxy localhost:8080
# }
#
# bit.dev.local {
#   tls internal
#   reverse_proxy localhost:3000
# }
#
# npm.dev.local {
#   tls internal
#   reverse_proxy localhost:4873
# }
