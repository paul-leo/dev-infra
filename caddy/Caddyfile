{
  local_certs
}

http://gitlab.internal.local {
  reverse_proxy gitlab:80
}

gitlab.internal.local {
  tls internal
  reverse_proxy gitlab:80
}

http://bit.internal.local {
  reverse_proxy bit:3000
}

bit.internal.local {
  tls internal
  reverse_proxy bit:3000
}

http://npm.internal.local {
  reverse_proxy {$BIT_REGISTRY_UPSTREAM} {
    header_up Host node-registry.bit.cloud
  }
}

npm.internal.local {
  tls internal
  reverse_proxy {$BIT_REGISTRY_UPSTREAM} {
    header_up Host node-registry.bit.cloud
  }
}
