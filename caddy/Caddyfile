# ─── Dev-Infra Caddy Reverse Proxy ───────────────────────────────────────────
#
# Domains are configured via environment variables:
#   GITLAB_DOMAIN, BIT_DOMAIN, NPM_DOMAIN, HARNESS_DOMAIN
#
# TLS is handled automatically by Caddy:
#   - Real domains → auto ACME (Let's Encrypt)
#   - .local / .internal / IP → auto self-signed ("internal")
#   - Set ACME_EMAIL for production Let's Encrypt
#
# ─────────────────────────────────────────────────────────────────────────────

# Global options
{
	# Email for ACME (Let's Encrypt) registration
	email {$ACME_EMAIL:}

	# Use internal CA for *.local / *.internal / IP addresses
	# Caddy auto-detects this for non-public domains
}

# ─── GitLab ──────────────────────────────────────────────────────────────────
{$GITLAB_DOMAIN:gitlab.localhost} {
	reverse_proxy gitlab:80
}

# ─── Bit Scope Server ────────────────────────────────────────────────────────
{$BIT_DOMAIN:bit.localhost} {
	reverse_proxy bit:3000
}

# ─── Verdaccio (npm registry) ────────────────────────────────────────────────
{$NPM_DOMAIN:npm.localhost} {
	reverse_proxy verdaccio:4873
}

# ─── Harness-FE Gateway ─────────────────────────────────────────────────────
{$HARNESS_DOMAIN:harness.localhost} {
	# WebSocket upgrade for runtime connections
	@websocket {
		header Connection *Upgrade*
		header Upgrade    websocket
	}
	reverse_proxy @websocket harness:9051

	# All other traffic → HTTP MCP endpoint
	reverse_proxy harness:9050
}
