# Optional overrides — copy to docker-compose.override.yml to activate.
# This file adds a Caddy reverse proxy for HTTPS / custom domains.
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   # Edit .env: ENABLE_HTTPS=true, BASE_DOMAIN=your-domain.local, TLS_MODE=internal
#   docker compose up -d

services:
  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    env_file: .env
    ports:
      - "${HOST_IP:-0.0.0.0}:${CADDY_HTTP_PORT:-9000}:80"
      - "${HOST_IP:-0.0.0.0}:${CADDY_HTTPS_PORT:-9443}:443"
    environment:
      BASE_DOMAIN: "${BASE_DOMAIN:-localhost}"
      TLS_MODE: "${TLS_MODE:-internal}"
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - ./data/caddy/data:/data
      - ./data/caddy/config:/config
      - ${CUSTOM_CERT_PATH:-./certs/cert.pem}:/certs/cert.pem:ro
      - ${CUSTOM_KEY_PATH:-./certs/key.pem}:/certs/key.pem:ro
    depends_on:
      - gitlab
      - verdaccio
      - bit
      - harness
