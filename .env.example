# ─── Project ─────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=dev-infra

# ─── Profiles (selective services) ───────────────────────────────────────────
# Core services (verdaccio + harness) always start.
# Add profiles to enable optional services:
#   gitlab  → GitLab CE + Runner
#   bit     → Bit scope server
#   all     → everything
#
# Examples:
#   COMPOSE_PROFILES=gitlab        → core + gitlab
#   COMPOSE_PROFILES=gitlab,bit    → core + gitlab + bit
#   COMPOSE_PROFILES=all           → all services
COMPOSE_PROFILES=all

# ─── Environment ─────────────────────────────────────────────────────────────
# Environment mode: development | staging | production
# Controls default behaviors (logging level, exposed ports, TLS, etc.)
ENV_MODE=development

# ─── Network ─────────────────────────────────────────────────────────────────
# 127.0.0.1  → localhost only (default)
# 0.0.0.0    → all interfaces (LAN accessible)
# 192.168.x.x → specific LAN interface
HOST_IP=127.0.0.1

# Base domain for all services (used by reverse proxy / demo env)
BASE_DOMAIN=localhost

# ─── Custom Hostnames (for reverse proxy / HTTPS setup) ──────────────────────
# If using a reverse proxy with custom domains, set these:
GITLAB_HOSTNAME=${BASE_DOMAIN}
BIT_HOSTNAME=${BASE_DOMAIN}
NPM_HOSTNAME=${BASE_DOMAIN}
HARNESS_HOSTNAME=${BASE_DOMAIN}
#
# Then set the external URLs accordingly:
# GITLAB_EXTERNAL_URL=https://gitlab.example.com
# GITLAB_EXTERNAL_URL must match GITLAB_EXTERNAL_URL setting below

# ─── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_IMAGE=gitlab/gitlab-ce:17.11.1-ce.0
GITLAB_PORT=9080
GITLAB_SSH_PORT=9022
GITLAB_EXTERNAL_URL=http://${GITLAB_HOSTNAME}:${GITLAB_PORT}
GITLAB_ROOT_PASSWORD=change-me-to-a-strong-password

# ─── GitLab Runner ───────────────────────────────────────────────────────────
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner:v17.11.1

# ─── Bit ─────────────────────────────────────────────────────────────────────
BIT_IMAGE=bitcli/bit-server:1.13.58-node-22.22.0
BIT_PORT=9030
BIT_SCOPE_NAME=dev-infra

# ─── Verdaccio (npm private registry) ────────────────────────────────────────
VERDACCIO_PORT=9040

# ─── Harness-FE (AI agent gateway) ──────────────────────────────────────────
# Harness-FE MCP gateway — connects AI agents to browser/server runtimes
# See: https://github.com/Morphicai/harness-fe
HARNESS_ENABLED=true
HARNESS_IMAGE=node:20-alpine
HARNESS_PORT=9050
HARNESS_WS_PORT=9051
# Gateway mode: solo (local dev) | governed (team with RBAC)
HARNESS_MODE=solo
# Project binding (used by governed mode)
HARNESS_PROJECT_ID=dev-infra
# Auth token for governed mode (leave empty for solo)
HARNESS_AUTH_TOKEN=

# ─── TLS / HTTPS (Optional) ──────────────────────────────────────────────────
# Set to true to enable HTTPS via Caddy reverse proxy
ENABLE_HTTPS=false
CADDY_HTTP_PORT=9000
CADDY_HTTPS_PORT=9443

# Certificate mode: internal (self-signed) | acme (Let's Encrypt) | custom
TLS_MODE=internal

# For Let's Encrypt (DNS challenge):
ACME_EMAIL=admin@example.com
ACME_DNS_PROVIDER=cloudflare
ACME_DNS_API_TOKEN=your-token

# For custom certificates:
CUSTOM_CERT_PATH=./certs/cert.pem
CUSTOM_KEY_PATH=./certs/key.pem

# ─── Persistence ─────────────────────────────────────────────────────────────
# Mount paths for data persistence
GITLAB_DATA_PATH=./data/gitlab
BIT_DATA_PATH=./data/bit
VERDACCIO_DATA_PATH=./data/verdaccio
RUNNER_DATA_PATH=./data/gitlab-runner
HARNESS_DATA_PATH=./data/harness

# ─── Demo Environment ────────────────────────────────────────────────────────
# Quick presets for demo / staging deployments.
# When DEMO_MODE=true, services expose on 0.0.0.0 and use BASE_DOMAIN hostnames.
DEMO_MODE=false
# Override ports in demo mode (all start from 90xx)
# DEMO_GITLAB_PORT=9080
# DEMO_BIT_PORT=9030
# DEMO_VERDACCIO_PORT=9040
# DEMO_HARNESS_PORT=9050
