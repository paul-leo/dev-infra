# ─── Project ─────────────────────────────────────────────────────────────────
# Docker Compose project name (affects container/network naming)
COMPOSE_PROJECT_NAME=dev-infra

# ─── Network ─────────────────────────────────────────────────────────────────
# IP address to bind all services to.
# 127.0.0.1  → localhost only
# 0.0.0.0    → all interfaces (LAN accessible)
# 192.168.x.x → specific LAN interface
HOST_IP=127.0.0.1

# ─── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_IMAGE=gitlab/gitlab-ce:17.11.1-ce.0

# Hostname used inside the container (affects cookie domain, SSH host key CN)
GITLAB_HOSTNAME=localhost

# Web port exposed on HOST_IP
GITLAB_PORT=8080

# SSH port exposed on HOST_IP
GITLAB_SSH_PORT=9022

# Full URL GitLab uses for clone URLs and web links.
# Must match http://HOST_IP:GITLAB_PORT (or your domain)
GITLAB_EXTERNAL_URL=http://localhost:8080

# Initial root password — change immediately after first login
GITLAB_ROOT_PASSWORD=change-me-long-random-password

# ─── GitLab Runner ───────────────────────────────────────────────────────────
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner:v17.11.1

# ─── Bit ─────────────────────────────────────────────────────────────────────
BIT_IMAGE=bitcli/bit-server:1.13.58-node-22.22.0

# Bit server port exposed on HOST_IP
BIT_PORT=3000

# Bit scope name — determines the scope path and remote URL
BIT_SCOPE_NAME=dev-infra
