# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║                        dev-infra configuration                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and edit to match your environment:
#   cp .env.example .env
#

# ─── Project ─────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=dev-infra

# ─── Profiles (selective services) ───────────────────────────────────────────
#
# Core services (verdaccio + harness) always start.
# Add profiles to enable optional services:
#
#   gitlab  → GitLab CE + Runner
#   bit     → Bit scope server
#   caddy   → Caddy reverse proxy (domain routing + auto HTTPS)
#   all     → everything
#
# Combine with commas:
#   COMPOSE_PROFILES=gitlab,caddy
#
COMPOSE_PROFILES=all

# ─── Environment ─────────────────────────────────────────────────────────────
# development | staging | production
ENV_MODE=development
NODE_ENV=development

# ─── Network ─────────────────────────────────────────────────────────────────
# Bind address for direct port access (without Caddy):
#   127.0.0.1   → localhost only (safe default)
#   0.0.0.0     → all interfaces (LAN / public)
#   192.168.x.x → specific interface
HOST_IP=127.0.0.1

# ─── Domain Configuration ────────────────────────────────────────────────────
#
# Pick the access pattern that fits your setup:
#
#   Option A — Direct ports (no Caddy):
#     BASE_DOMAIN=localhost
#     → http://localhost:9080 (GitLab), http://localhost:9040 (Verdaccio), ...
#
#   Option B — Caddy vhost routing (single entry point):
#     BASE_DOMAIN=localhost            # default: gitlab.localhost etc.
#     BASE_DOMAIN=dev.your-domain.com  # gitlab.dev.your-domain.com etc.
#     → Add DNS A records (or /etc/hosts entries) for each subdomain.
#
BASE_DOMAIN=localhost

# Per-service domain overrides (default: <service>.${BASE_DOMAIN})
# Uncomment to customise individual services:
# GITLAB_DOMAIN=gitlab.your-domain.com
# BIT_DOMAIN=bit.your-domain.com
# NPM_DOMAIN=npm.your-domain.com
# HARNESS_DOMAIN=harness.your-domain.com

# ─── Caddy (Reverse Proxy) ───────────────────────────────────────────────────
# Enable via: COMPOSE_PROFILES=caddy (or "all")
#
# Caddy listens on these ports. The same values are used by docker-compose
# for host port mapping AND by the Caddyfile (http_port / https_port), so
# changing them in one place updates everything.
#
CADDY_IMAGE=caddy:2-alpine
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ─── TLS / HTTP mode ─────────────────────────────────────────────────────────
#
# Pick exactly one of the four modes below. Uncomment the block that matches
# your deployment, leave the others commented.
#
#   AUTO_HTTPS  → Caddy's global auto-HTTPS behaviour  (on | off)
#   TLS_SNIPPET → which TLS snippet the Caddyfile imports per site:
#                   tls-none      plain HTTP (use with AUTO_HTTPS=false)
#                   tls-internal  Caddy's built-in self-signed CA
#                   tls-custom    load /certs/cert.pem + /certs/key.pem
#                   (empty)       let Caddy auto-issue (ACME) for public domains
#
# ─── Mode 1: Plain HTTP (development, internal networks) ────────────────────
AUTO_HTTPS=false
TLS_SNIPPET=tls-none
# ACME_EMAIL=
# CUSTOM_CERT_PATH=./certs/cert.pem
# CUSTOM_KEY_PATH=./certs/key.pem

# ─── Mode 2: Public domain with Let's Encrypt ────────────────────────────────
# Requirements: DNS A records for each subdomain, ports 80 + 443 reachable
# from the internet, ACME_EMAIL set.
# AUTO_HTTPS=true
# TLS_SNIPPET=tls-none
# ACME_EMAIL=admin@your-domain.com

# ─── Mode 3: .local / .internal with Caddy's self-signed CA ──────────────────
# Useful for LAN deployments where Let's Encrypt is unreachable.
# Clients must trust Caddy's root CA — extract with:
#   docker compose cp caddy:/data/caddy/pki/authorities/local/root.crt ./caddy-root.crt
# AUTO_HTTPS=true
# TLS_SNIPPET=tls-internal
# ACME_EMAIL=

# ─── Mode 4: Custom certificate (corporate CA, purchased cert) ──────────────
# Place your files in ./certs/ (or override CUSTOM_CERT_PATH / CUSTOM_KEY_PATH).
# Run ./scripts/gen-certs.sh to generate a self-signed Root CA + leaf cert.
# AUTO_HTTPS=false
# TLS_SNIPPET=tls-custom
# CUSTOM_CERT_PATH=./certs/cert.pem
# CUSTOM_KEY_PATH=./certs/key.pem
# ACME_EMAIL=

# ─── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_IMAGE=gitlab/gitlab-ce:17.11.1-ce.0
GITLAB_HOSTNAME=gitlab
GITLAB_PORT=9080
GITLAB_SSH_PORT=9022
GITLAB_ROOT_PASSWORD=change-me-to-a-strong-password

# External URL — how users access GitLab from their browser.
# Without Caddy: http://<ip>:9080
# With Caddy:    https://gitlab.${BASE_DOMAIN}
GITLAB_EXTERNAL_URL=http://localhost:9080

# ─── GitLab Runner ───────────────────────────────────────────────────────────
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner:v17.11.1

# ─── Bit ─────────────────────────────────────────────────────────────────────
BIT_IMAGE=bitcli/bit-server:1.13.58-node-22.22.0
BIT_PORT=9030
BIT_SCOPE_NAME=dev-infra

# ─── Verdaccio (npm private registry) ────────────────────────────────────────
VERDACCIO_VERSION=5
VERDACCIO_PORT=9040

# ─── Harness-FE (AI Agent MCP Gateway) ──────────────────────────────────────
# Docs: https://github.com/Morphicai/harness-fe
HARNESS_IMAGE=node:20-alpine
HARNESS_PORT=9050
HARNESS_WS_PORT=9051
# Gateway mode: solo (single dev) | governed (team RBAC + audit)
HARNESS_MODE=solo
HARNESS_PROJECT_ID=dev-infra
# Auth token — required for governed mode, ignored in solo
HARNESS_AUTH_TOKEN=

# ─── Persistence ─────────────────────────────────────────────────────────────
# All runtime data lives under ./data/ (gitignored).
# Change paths to use external volumes or different mount points.
GITLAB_DATA_PATH=./data/gitlab
RUNNER_DATA_PATH=./data/gitlab-runner
BIT_DATA_PATH=./data/bit
VERDACCIO_DATA_PATH=./data/verdaccio
HARNESS_DATA_PATH=./data/harness
CADDY_DATA_PATH=./data/caddy
