# Copy to .env and edit before starting.

# Hostnames resolved by internal DNS only.
BASE_DOMAIN=internal.local
HOST_IP=192.168.1.100

GITLAB_HOST=gitlab.internal.local
NPM_HOST=npm.internal.local
BIT_HOST=bit.internal.local

# GitLab ports are only bound on HOST_IP by docker-compose.yml.
GITLAB_HTTP_PORT=8080
GITLAB_SSH_PORT=2222

# GitLab initial root password. Change immediately after first login.
GITLAB_ROOT_PASSWORD=change-me-long-random-password

# Registry choice:
# - GitLab Package Registry is available through GitLab.
# - Verdaccio is optional for lightweight npm package hosting.
VERDACCIO_PORT=4873

# TLS mode:
# - internal-ca: use your own certificates mounted under ./caddy/certs
# - dns01: configure Caddy DNS plugin in a custom Caddy image
TLS_MODE=internal-ca

