# ─── Project ─────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=dev-infra

# ─── Network ─────────────────────────────────────────────────────────────────
# 127.0.0.1  → localhost only (default)
# 0.0.0.0    → all interfaces (LAN accessible)
# 192.168.x.x → specific LAN interface
HOST_IP=127.0.0.1

# ─── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_IMAGE=gitlab/gitlab-ce:17.11.1-ce.0
GITLAB_HOSTNAME=localhost
GITLAB_PORT=8080
GITLAB_SSH_PORT=9022
GITLAB_EXTERNAL_URL=http://localhost:8080
GITLAB_ROOT_PASSWORD=change-me-to-a-strong-password

# ─── GitLab Runner ───────────────────────────────────────────────────────────
GITLAB_RUNNER_IMAGE=gitlab/gitlab-runner:v17.11.1

# ─── Bit ─────────────────────────────────────────────────────────────────────
BIT_IMAGE=bitcli/bit-server:1.13.58-node-22.22.0
BIT_PORT=3000
BIT_SCOPE_NAME=dev-infra

# ─── Verdaccio ───────────────────────────────────────────────────────────────
VERDACCIO_PORT=4873
