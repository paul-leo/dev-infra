# Copy to .env and edit before starting.

# Hostnames are not required for LAN access.
BASE_DOMAIN=internal.local
HOST_IP=192.168.1.100
GITLAB_HOST=gitlab.internal.local
NPM_HOST=npm.internal.local
BIT_HOST=bit.internal.local

# GitLab SSH is exposed separately so it does not consume port 22.
GITLAB_SSH_PORT=9006

# GitLab initial root password. Change immediately after first login.
GITLAB_ROOT_PASSWORD=change-me-long-random-password

# Bit Cloud registry proxy used by npm.internal.local.
BIT_REGISTRY_UPSTREAM=https://node-registry.bit.cloud

# Internal access uses plain HTTP on the ports above.
# HTTPS is reserved for later external exposure.
